[alias]
    a           = add
    ai          = add -p
    au          = add -u
    br          = branch
    brd         = branch -D
    cl          = clone --recursive 
    c           = commit -m
    ca          = commit --amend
    co          = checkout
#    cb          = checkout -b
    df          = diff
    dfc         = diff --cached
    f           = fetch
    fa          = fetch --all
    fpr         = fetch --prune
    ff          = !git fa && git pl
    p           = !git push origin `git symbolic-ref HEAD`
    pf          = !git push origin +`git symbolic-ref HEAD`
    pt		      = !git push --tag
    pl          = !git pull origin `git symbolic-ref HEAD`
    patch       = !git --no-pager diff --no-color
    #prune      = !git pull origin --prune ### This command doesn't work
    sh          = show
    sw          = switch
    swc         = switch -c
#[rebase]
    rb          = rebase
    rba         = rebase --abort
    rbc         = rebase --continue
    rbi         = rebase -i
    cp		      = cherry-pick
    cpa		      = cherry-pick --abort
    cpc		      = cherry-pick --continue
#[reset]
    r           = reset
    rs          = reset --soft
    rh          = reset --hard
    undo        = reset --soft HEAD^
#[stash]
    s           = stash save
    sa          = stash apply
    sp          = stash pop
    sl          = stash list
    ss          = stash show
    sd          = stash drop
#[log]
    hist          = log --pretty=format:\"%h %ad (%ar) | %s%d [author: %an]\" --graph --date=short
    lo	          = !git hist | head -n 10
    loo           = !git hist | head -n 20
    log-files     = log --graph --abbrev-commit --left-right --name-only
#    show-last     = show --pretty="format:" --name-only # `git describe --always`
#    show-prev     = diff-tree --no-commit-id --name-only -r `git rev-parse --short HEAD`
    st            = status # --short
    tree          = log --all --decorate --oneline --graph
# Show git commands
    commands      = help -a
# Show current repo's name
    name          = !git remote -v | head -n1 | awk '{print $2}'

