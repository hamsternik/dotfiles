Include ~/.ssh/config.local

Host *
  IgnoreUnknown UseKeychain
  AddKeysToAgent yes
  UseKeychain yes

# NOTE: Personal account.
# To add the private key to the ssh-agent manually:
# ssh-add ~/.ssh/hamsternik.github.com
# Connection sanity check: ssh -T git@github.com
Host github.com
  HostName github.com
  IdentityFile ~/.ssh/github.hamsternik
  IdentitiesOnly yes

# NOTE: Github work account.
# Use the standard pattern to manage multiple gh accounts.
# ssh-add ~/.ssh/work.github.com
# Sanity check work account: ssh -T git@work.github.com
Host work.github.com
  HostName github.com
  IdentityFile ~/.ssh/github.work
  IdentitiesOnly yes

Host gitlab.com
     HostName gitlab.com
     IdentityFile ~/.ssh/gitlab.hamsternik

Host codeberg.org
    HostName codeberg.org
    IdentityFile ~/.ssh/codeberg.hamsternik